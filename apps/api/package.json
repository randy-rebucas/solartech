{
  "name": "@solartech/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":        "npm run build -w @solartech/shared && nest start --watch",
    "build":      "npm run build -w @solartech/shared && nest build",
    "start":      "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint":       "eslint src --ext .ts",
    "test":       "jest",
    "test:e2e":   "jest --config ./test/jest-e2e.json",
    "db:seed":    "ts-node src/database/seed.ts",
    "db:seed:keep": "ts-node src/database/seed.ts -- --keep"
  },
  "dependencies": {
    "@solartech/shared": "*",
    "@nestjs/cli":            "^10.4.9",
    "@nestjs/common":         "^10.4.15",
    "@nestjs/core":           "^10.4.15",
    "@nestjs/platform-express":"^10.4.15",
    "@nestjs/jwt":            "^10.2.0",
    "@nestjs/passport":       "^10.0.3",
    "@nestjs/mongoose":       "^10.1.0",
    "@nestjs/config":         "^3.3.0",
    "@nestjs/throttler":      "^6.3.0",
    "@nestjs/swagger":        "^8.1.0",
    "@nestjs/websockets":     "^10.4.15",
    "@nestjs/platform-socket.io": "^10.4.15",
    "@nestjs/schedule":       "^4.1.2",
    "@nestjs/bull":           "^10.2.3",
    "mongoose":               "^8.9.4",
    "passport":               "^0.7.0",
    "passport-jwt":           "^4.0.1",
    "passport-local":         "^1.0.0",
    "passport-google-oauth20":"^2.0.0",
    "passport-github2":       "^0.1.12",
    "bcryptjs":               "^2.4.3",
    "speakeasy":              "^2.0.0",
    "qrcode":                 "^1.5.4",
    "jsonwebtoken":           "^9.0.2",
    "ioredis":                "^5.4.2",
    "bull":                   "^4.16.5",
    "socket.io":              "^4.8.1",
    "mqtt":                   "^5.10.3",
    "class-validator":        "^0.14.1",
    "class-transformer":      "^0.5.1",
    "reflect-metadata":       "^0.2.2",
    "rxjs":                   "^7.8.1",
    "nodemailer":             "^6.9.16",
    "openai":                 "^4.77.3",
    "stripe":                 "^17.5.0",
    "axios":                  "^1.7.9",
    "uuid":                   "^11.0.5",
    "helmet":                 "^8.0.0",
    "compression":            "^1.7.5"
  },
  "devDependencies": {
    "@nestjs/testing":        "^10.4.15",
    "@types/express":         "^5.0.0",
    "@types/passport-jwt":    "^4.0.1",
    "@types/bcryptjs":        "^2.4.6",
    "@types/nodemailer":      "^6.4.17",
    "@types/qrcode":          "^1.5.5",
    "@types/uuid":            "^10.0.0",
    "typescript":             "^5.7.3",
    "ts-node":                "^10.9.2",
    "ts-jest":                "^29.2.5",
    "jest":                   "^29.7.0",
    "supertest":              "^7.0.0"
  }
}
