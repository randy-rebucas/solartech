# ─────────────────────────────────────────────────────────────────────────────
# SolarTech Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Frontend (apps/web) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── Backend (apps/api) ───────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_USER=solartech
MONGO_PASSWORD=solartech_dev
MONGODB_URI=mongodb://solartech:solartech_dev@localhost:27017/solartech?authSource=admin

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=solartech_dev
REDIS_URL=redis://:solartech_dev@localhost:6379

# ── JWT (REQUIRED — use long random strings) ─────────────────────────────────
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET_MIN_32_CHARS_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS_RANDOM
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/oauth/google/callback

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:4000/api/v1/auth/oauth/github/callback

# ── Email ────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@solartech.ph

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── MQTT (optional in dev — set true when mosquitto is running) ───────────────
MQTT_ENABLED=false
MQTT_BROKER_URL=mqtt://127.0.0.1:1883
MQTT_USERNAME=solartech
MQTT_PASSWORD=solartech_dev

# ── API (Server Actions use API_URL; browser uses NEXT_PUBLIC_API_URL) ───────
API_URL=http://127.0.0.1:4000
